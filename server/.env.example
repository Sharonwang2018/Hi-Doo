PORT=3000
# 本地: postgresql://localhost:5432/echo_reading
# Supabase: Settings → Database → Connection string (URI)，把 [YOUR-PASSWORD] 换成 Database password（不是 anon key）。
# 密码含 @ # : / ? 等须先 URL 编码再放进 URI。Pooler 用户名可能是 postgres.<ref>，请整段复制控制台，勿手写。
# 自检: cd server && npm run check-db（Supabase 连接由 server/pg_config.js 处理 TLS，无需改 URI）
DATABASE_URL=postgresql://localhost:5432/echo_reading
# 可选：Session pooler（5432）写在 DIRECT_URL；若与 DATABASE_URL 同时存在，优先使用 DIRECT_URL。
# DIRECT_URL=postgresql://postgres.xxx:PASSWORD@aws-0-xxx.pooler.supabase.com:5432/postgres
# （Supabase 可省略 ?sslmode=require，api/pg_config.js 会处理 TLS）
# 启动日志里展示的公网入口（可选），例如 http://luckycloudy.com:3000
# PUBLIC_BASE_URL=http://luckycloudy.com:3000
# Supabase：与 Flutter 同一项目 URL（无末尾斜杠），用于校验 ECC/ES256 等新签名方式的 access token（JWKS）
SUPABASE_URL=https://your-project-ref.supabase.co
# Legacy HS256 用户 token 仍可用此项校验；若 Dashboard 已切到 JWT Signing Keys（ECC），必须配置 SUPABASE_URL
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
UPLOAD_DIR=./uploads

# Chat (optional): prefer Groq when GROQ_API_KEY is set; else Ark, then OpenRouter.
# ARK_API_KEY=xxx
# ARK_ENDPOINT_ID=ep-xxxx
# OPENROUTER_API_KEY=sk-or-v1-xxx
# OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Groq: /api/assessment — retelling listener + book_comprehension (title/author questions & hints)
# GROQ_API_KEY=gsk_xxx
# GROQ_MODEL=llama-3.3-70b-versatile

# POST /api/tts — 优先 OpenAI 语音（自然度高）；未配或失败时可用火山豆包。Flutter 已配置 API_BASE_URL 时会请求此接口。
# OpenAI：https://platform.openai.com/docs/guides/text-to-speech
# OPENAI_API_KEY=sk-xxx
# 可选：tts-1（快）或 tts-1-hd；音色 alloy, echo, fable, onyx, nova, shimmer（默认 nova，偏友好）
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=shimmer
# OPENAI_TTS_TIMEOUT_MS=90000
# 豆包语音（备选）说明见 docs/DOUBAO_SETUP.md
# 使用 HTTP 非流式 79820，与控制台「1329505 WebSocket」不是同一接法；2.0 字符版需按大模型文档填 cluster/voice_type
# VOLC_TTS_APP_ID=
# VOLC_TTS_ACCESS_TOKEN=
# 与 ACCESS_TOKEN 二选一：控制台「API Key」时常填此项（仍须配 VOLC_TTS_APP_ID）
# VOLC_TTS_API_KEY=
# VOLC_TTS_CLUSTER=volcano_tts
# 请求豆包 openspeech 的最长等待（毫秒），默认 90000
# VOLC_TTS_FETCH_TIMEOUT_MS=90000
# VOLC_TTS_VOICE_TYPE=BV700_streaming
# 可选，大模型音质：seed-tts-1.1（见文档 6561/1257584）
# VOLC_TTS_MODEL=seed-tts-1.1

# Optional daily API quotas (default: OFF). Donation is app UI only, not tied to quotas.
# QUOTA_ENABLED=1
# QUOTA_TRANSCRIBE_ANON_PER_DAY=12
# QUOTA_TRANSCRIBE_REGISTERED_PER_DAY=45
# QUOTA_TTS_ANON_PER_DAY=45
# QUOTA_TTS_REGISTERED_PER_DAY=150
# QUOTA_CHAT_ANON_PER_DAY=14
# QUOTA_CHAT_REGISTERED_PER_DAY=60
# QUOTA_ASSESSMENT_ANON_PER_DAY=14
# QUOTA_ASSESSMENT_REGISTERED_PER_DAY=60

# Flutter web only: optional donation link (Buy Me a Coffee, Stripe Payment Link, etc.)
# export DONATION_URL=https://buymeacoffee.com/yourpage
# then ./run_all.sh passes it as --dart-define=DONATION_URL

# Vercel (Edge middleware.js): public URL of THIS Node API, no trailing slash
# BACKEND_ORIGIN=https://your-api.railway.app
