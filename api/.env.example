PORT=3000
DATABASE_URL=postgresql://localhost:5432/echo_reading
JWT_SECRET=your-secret-key-change-in-production
UPLOAD_DIR=./uploads

# 对话/AI 审阅、拍照读页：二选一（同时配置时优先豆包）
# ARK_API_KEY=xxx
# ARK_ENDPOINT_ID=ep-xxxx
# ARK_VISION_ENDPOINT_ID=ep-yyyy
# OPENROUTER_API_KEY=sk-or-v1-xxx
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
# OPENROUTER_VISION_MODEL=openrouter/free

# 朗读（拍照读页等）：豆包语音优先，见 docs/DOUBAO_SETUP.md
# 使用 HTTP 非流式 79820，与控制台「1329505 WebSocket」不是同一接法；2.0 字符版需按大模型文档填 cluster/voice_type
# VOLC_TTS_APP_ID=
# VOLC_TTS_ACCESS_TOKEN=
# 与 ACCESS_TOKEN 二选一：控制台「API Key」时常填此项（仍须配 VOLC_TTS_APP_ID）
# VOLC_TTS_API_KEY=
# VOLC_TTS_CLUSTER=volcano_tts
# 请求豆包 openspeech 的最长等待（毫秒），默认 90000
# VOLC_TTS_FETCH_TIMEOUT_MS=90000
# VOLC_TTS_VOICE_TYPE=BV700_streaming
# 可选，大模型音质：seed-tts-1.1（见文档 6561/1257584）
# VOLC_TTS_MODEL=seed-tts-1.1
# OPENAI_API_KEY=sk-xxx
