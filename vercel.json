{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1"],
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "build/web",
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/books", "destination": "/api" },
    { "source": "/books/:path*", "destination": "/api" },
    { "source": "/read-logs", "destination": "/api" },
    { "source": "/read-logs/:path*", "destination": "/api" },
    { "source": "/upload", "destination": "/api" },
    { "source": "/upload/:path*", "destination": "/api" },
    { "source": "/audio", "destination": "/api" },
    { "source": "/audio/:path*", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
